      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst prData = $('Get PR Data').first().json;\nconst diff = $('Fetch PR Difference').first().json.data || '';\nconst labels = prData.additions + prData.deletions > 200 ? ['size/L'] : ['size/S'];\nreturn [{ json: { ...prData, diffPreview: diff.substring(0, 3000), suggestedLabels: labels } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
