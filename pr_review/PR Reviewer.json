    },
    {
      "parameters": {
        "jsCode": "const output = $input.first().json.output;\nconst prData = $('Analyze File Changes').first().json;\nconst review = { qualityScore: 85, summary: \"AI Analysis Complete\", approvalRecommendation: \"approve\" };\nreturn [{ json: { ...prData, aiReview: review, finalLabels: prData.suggestedLabels, reviewComment: JSON.parse(output) } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1600,
        0
      ],
      "id": "66c8d6e5-dbb1-4dd4-92bc-c1ad0d712707",
      "name": "Parse Review"
    },
    {
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "reviewComment = _items[0]['json']['reviewComment']\nrepoOwner = _items[0]['json']['repoOwner']\nrepoName = _items[0]['json']['repoName']\nprNumber = _items[0]['json']['prNumber']\n\nqualityScore = reviewComment['qualityScore']\n\ndef formating(key_name):\n  output = ''\n  if key_name in reviewComment:\n    response = reviewComment[key_name]\n    if isinstance(response, list):\n      indx = 1\n      for i in range(len(response)):\n        output += str(indx) + ' - ' + response[i] + '<br>'\n        indx += 1\n      output = output[:-4]\n    else:\n      output = response\n    return output\n  else:\n    return 'NA'\n\nstrengths = formating('strengths')\n\nconcerns = formating('concerns')\n\nsuggestions = formating('suggestions')\n\nsummary = formating('summary')\n\n\nreturn {\"repoOwner\" : repoOwner, \"repoName\": repoName, \"prNumber\": prNumber, \"qualityScore\": qualityScore, \"strengths\": strengths, \"concerns\": concerns, \"suggestions\": suggestions, \"summary\": summary}"
      },
